# ==============================================================================
# Autonomous Code Reviewer - Local Environment Configurations Example
# ==============================================================================

# General Application Config
APP_NAME="Autonomous Code Reviewer AI"
APP_ENV="development"                  # "development" or "production"
API_V1_STR="/api/v1"
SECRET_KEY="your-secure-random-secret-key-here"

# Database Configuration (Defaults to SQLite for local runs)
DATABASE_URL="sqlite:///./code_reviewer.db"

# Storage Settings (Local working path for cloning/unpacking repositories)
TEMP_STORAGE_PATH="./storage/temp"
MAX_UPLOAD_SIZE_MB=100
CLONE_TIMEOUT_SEC=60

# LLM Review Agent Configuration
LLM_PROVIDER=groq                    # "groq", "anthropic", "openai", "local"
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="openai/gpt-oss-120b"

# Legacy / shared settings (kept for backward compatibility)
REVIEW_MODEL="openai/gpt-oss-120b"
REVIEW_TEMPERATURE=0.0
REVIEW_MAX_TOKENS=4000
REVIEW_CONTEXT_WINDOW_LIMIT=180000
REVIEW_MAX_RETRIES=3
REVIEW_TIMEOUT_SEC=60.0

# Token Cost (per 1M tokens — Groq pricing)
REVIEW_COST_INPUT_1M=0.60
REVIEW_COST_OUTPUT_1M=0.90

# RAG & Embedding Service Configuration — Local Sentence Transformers (zero-cost)
EMBEDDING_PROVIDER="local"                  # "local", "openai", "anthropic"
LOCAL_EMBEDDING_MODEL="all-MiniLM-L6-v2"    # Default SentenceTransformer model (~80 MB)
EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS=384                    # 384-dim for all-MiniLM-L6-v2
RAG_BATCH_SIZE=100
RAG_REQUEST_TIMEOUT=30.0
RAG_MAX_RETRIES=3

# Standalone ChromaDB Server Configuration
CHROMA_HOST="localhost"               # Use "chromadb" inside Docker network
CHROMA_PORT=8000
CHROMA_PERSIST_DIR="./chroma_db"
CHROMA_COLLECTION_NAME="codebase_index"
