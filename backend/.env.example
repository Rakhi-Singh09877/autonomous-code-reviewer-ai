# General Application Configuration
APP_ENV=development
APP_NAME="Autonomous Code Reviewer AI (RAG & MCP Edition)"
API_V1_STR="/api/v1"
SECRET_KEY="replace-this-with-a-secure-random-secret-key-in-production"

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/code_reviewer"

# Task Queue and Broker
REDIS_URL="redis://localhost:6379/0"

# ---- AI Model Provider Configuration ----
# Primary LLM Provider
LLM_PROVIDER=groq                    # "groq", "anthropic", "openai", "local"
GROQ_API_KEY="your-groq-api-key"

GROQ_MODEL="openai/gpt-oss-120b"     # Model served via the OpenAI-compatible endpoint

# Review Tuning (shared across providers)
REVIEW_TEMPERATURE=0.0
REVIEW_MAX_TOKENS=4000
REVIEW_CONTEXT_WINDOW_LIMIT=180000
REVIEW_MAX_RETRIES=3
REVIEW_TIMEOUT_SEC=60.0

# Token Cost Config (per 1 Million tokens)
# Groq pricing for openai/gpt-oss-120b
REVIEW_COST_INPUT_1M=0.60
REVIEW_COST_OUTPUT_1M=0.90

# RAG / Embedding — Local Sentence Transformers (zero-cost, runs on CPU/GPU)
EMBEDDING_PROVIDER=local                       # "local", "openai", "anthropic"
LOCAL_EMBEDDING_MODEL="all-MiniLM-L6-v2"       # ~80 MB download, 384-dim embeddings
EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS=384
RAG_BATCH_SIZE=100
RAG_REQUEST_TIMEOUT=30.0
RAG_MAX_RETRIES=3

# Vector Store
VECTOR_DB_DIR="./chroma_db"
CHROMA_HOST="localhost"
CHROMA_PORT=8000

# LangChain/LangSmith Tracing and Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langsmith-api-key-here"
LANGCHAIN_PROJECT="autonomous-code-reviewer-ai"

# Model Context Protocol (MCP) Configuration
MCP_PORT=8500
MCP_SERVER_NAME="reviewer-mcp-server"

# Storage Settings
STORAGE_PROVIDER="local"          # "local" or "s3"
AWS_ACCESS_KEY_ID="your-aws-access-key-here"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key-here"
AWS_BUCKET_NAME="your-s3-bucket-name"
LOCAL_STORAGE_PATH="./storage"
